{
  "project_url": "https://github.com/bearlyai/crossbins",
  "tools": [
    {
      "name": "rg",
      "repo": "BurntSushi/ripgrep",
      "binary_name": "rg",
      "asset_prefix": "ripgrep-{VERSION}-",
      "triple_map": {
        "aarch64-apple-darwin":          { "os": "darwin",  "arch": "aarch64" },
        "x86_64-apple-darwin":           { "os": "darwin",  "arch": "x86_64" },
        "aarch64-unknown-linux-gnu":     { "os": "linux",   "arch": "aarch64" },
        "x86_64-unknown-linux-musl":     { "os": "linux",   "arch": "x86_64",  "variant": "musl" },
        "i686-unknown-linux-gnu":        { "os": "linux",   "arch": "i686" },
        "armv7-unknown-linux-gnueabihf": { "os": "linux",   "arch": "armv7" },
        "armv7-unknown-linux-musleabihf":{ "os": "linux",   "arch": "armv7",   "variant": "musl" },
        "s390x-unknown-linux-gnu":       { "os": "linux",   "arch": "s390x" },
        "x86_64-pc-windows-msvc":        { "os": "windows", "arch": "x86_64" },
        "aarch64-pc-windows-msvc":       { "os": "windows", "arch": "aarch64" },
        "i686-pc-windows-msvc":          { "os": "windows", "arch": "i686" }
      }
    },
    {
      "name": "bun",
      "repo": "oven-sh/bun",
      "binary_name": "bun",
      "asset_prefix": "bun-",
      "triple_map": {
        "darwin-aarch64":      { "os": "darwin",  "arch": "aarch64" },
        "darwin-x64":          { "os": "darwin",  "arch": "x86_64" },
        "linux-x64":           { "os": "linux",   "arch": "x86_64" },
        "linux-aarch64":       { "os": "linux",   "arch": "aarch64" },
        "linux-x64-musl":      { "os": "linux",   "arch": "x86_64",  "variant": "musl" },
        "linux-aarch64-musl":  { "os": "linux",   "arch": "aarch64", "variant": "musl" },
        "windows-x64":         { "os": "windows", "arch": "x86_64" }
      }
    },
    {
      "name": "uv",
      "repo": "astral-sh/uv",
      "binary_name": "uv",
      "asset_prefix": "uv-",
      "triple_map": {
        "x86_64-apple-darwin":              { "os": "darwin",  "arch": "x86_64" },
        "aarch64-apple-darwin":             { "os": "darwin",  "arch": "aarch64" },
        "x86_64-unknown-linux-gnu":         { "os": "linux",   "arch": "x86_64" },
        "aarch64-unknown-linux-gnu":        { "os": "linux",   "arch": "aarch64" },
        "x86_64-unknown-linux-musl":        { "os": "linux",   "arch": "x86_64",  "variant": "musl" },
        "aarch64-unknown-linux-musl":       { "os": "linux",   "arch": "aarch64", "variant": "musl" },
        "i686-unknown-linux-gnu":           { "os": "linux",   "arch": "i686" },
        "i686-unknown-linux-musl":          { "os": "linux",   "arch": "i686",    "variant": "musl" },
        "armv7-unknown-linux-gnueabihf":    { "os": "linux",   "arch": "armv7" },
        "armv7-unknown-linux-musleabihf":   { "os": "linux",   "arch": "armv7",   "variant": "musl" },
        "arm-unknown-linux-musleabihf":     { "os": "linux",   "arch": "arm",     "variant": "musl" },

        "powerpc64le-unknown-linux-gnu":    { "os": "linux",   "arch": "ppc64le" },
        "s390x-unknown-linux-gnu":          { "os": "linux",   "arch": "s390x" },
        "riscv64gc-unknown-linux-gnu":      { "os": "linux",   "arch": "riscv64" },
        "x86_64-pc-windows-msvc":           { "os": "windows", "arch": "x86_64" },
        "aarch64-pc-windows-msvc":          { "os": "windows", "arch": "aarch64" },
        "i686-pc-windows-msvc":             { "os": "windows", "arch": "i686" }
      }
    },
    {
      "name": "yt-dlp",
      "repo": "yt-dlp/yt-dlp",
      "binary_name": "yt-dlp",
      "explicit_assets": [
        { "asset_name": "yt-dlp_linux",            "source_type": "raw", "os": "linux",   "arch": "x86_64" },
        { "asset_name": "yt-dlp_linux_aarch64",     "source_type": "raw", "os": "linux",   "arch": "aarch64" },
        { "asset_name": "yt-dlp_linux_armv7l.zip",  "source_type": "zip", "binary_name": "yt-dlp_linux_armv7l", "os": "linux",   "arch": "armv7" },
        { "asset_name": "yt-dlp_musllinux",         "source_type": "raw", "os": "linux",   "arch": "x86_64",  "variant": "musl" },
        { "asset_name": "yt-dlp_musllinux_aarch64", "source_type": "raw", "os": "linux",   "arch": "aarch64", "variant": "musl" },
        { "asset_name": "yt-dlp_macos",             "source_type": "raw", "os": "darwin",  "arch": "universal" },
        { "asset_name": "yt-dlp.exe",               "source_type": "raw", "os": "windows", "arch": "x86_64" },
        { "asset_name": "yt-dlp_arm64.exe",          "source_type": "raw", "os": "windows", "arch": "aarch64" },
        { "asset_name": "yt-dlp_x86.exe",           "source_type": "raw", "os": "windows", "arch": "i686" }
      ]
    },
    {
      "name": "ffmpeg",
      "repo": "BtbN/FFmpeg-Builds",
      "binary_name": "ffmpeg",
      "release_tag_pattern": "^autobuild-",
      "version_probe_regex": "^ffmpeg-n.*-gpl-(?<version>[0-9]+\\.[0-9]+)\\.(tar\\.xz|zip)$",
      "checksum_asset": "checksums.sha256",
      "explicit_assets": [
        { "asset_regex": "^ffmpeg-n.*-linux64-gpl-{VERSION}\\.tar\\.xz$",     "source_type": "tar.xz", "os": "linux",   "arch": "x86_64",  "variant": "gpl" },
        { "asset_regex": "^ffmpeg-n.*-linuxarm64-gpl-{VERSION}\\.tar\\.xz$",  "source_type": "tar.xz", "os": "linux",   "arch": "aarch64", "variant": "gpl" },
        { "asset_regex": "^ffmpeg-n.*-win64-gpl-{VERSION}\\.zip$",            "source_type": "zip",    "os": "windows", "arch": "x86_64",  "variant": "gpl" },
        { "asset_regex": "^ffmpeg-n.*-winarm64-gpl-{VERSION}\\.zip$",         "source_type": "zip",    "os": "windows", "arch": "aarch64", "variant": "gpl" },
        { "url": "https://ffmpeg.martin-riedl.de/redirect/latest/macos/amd64/release/ffmpeg.zip", "checksum_url": "{EFFECTIVE_URL}.sha256", "checksum_name": "ffmpeg.zip", "version_check_regex": "_{VERSION}(\\.[0-9]+)?/", "source_type": "zip", "os": "darwin", "arch": "x86_64", "variant": "gpl" },
        { "url": "https://ffmpeg.martin-riedl.de/redirect/latest/macos/arm64/release/ffmpeg.zip", "checksum_url": "{EFFECTIVE_URL}.sha256", "checksum_name": "ffmpeg.zip", "version_check_regex": "_{VERSION}(\\.[0-9]+)?/", "source_type": "zip", "os": "darwin", "arch": "aarch64", "variant": "gpl" }
      ]
    },
    {
      "name": "cua-driver",
      "repo": "trycua/cua",
      "binary_name": "cua-driver",
      "release_tag_pattern": "^cua-driver-rs-v",
      "include_prereleases": true,
      "version_probe_regex": "^cua-driver-rs-(?<version>[0-9]+\\.[0-9]+\\.[0-9]+)-.*$",
      "checksum_asset": "checksums.txt",
      "explicit_assets": [
        {
          "asset_name": "cua-driver-rs-{VERSION}-darwin-universal.tar.gz",
          "source_type": "tar.gz",
          "preserve_archive": true,
          "output_extension": ".tar.gz",
          "os": "darwin",
          "arch": "universal",
          "macos_app_rewrap": {
            "source_app_name": "CuaDriver.app",
            "app_name": "Bearly Computer Use Helper.app",
            "bundle_id": "com.bearly.computer-use-helper",
            "display_name": "Bearly Computer Use Helper",
            "archive_root": "bearly-computer-use-helper-{VERSION}-darwin-universal",
            "license_file": "licenses/cua-driver-MIT.md",
            "root_binary_name": "cua-driver"
          }
        },
        { "asset_name": "cua-driver-rs-{VERSION}-linux-x86_64-binary.tar.gz", "source_type": "tar.gz", "os": "linux", "arch": "x86_64" },
        { "asset_name": "cua-driver-rs-{VERSION}-linux-arm64-binary.tar.gz", "source_type": "tar.gz", "os": "linux", "arch": "aarch64" },
        { "asset_name": "cua-driver-rs-{VERSION}-windows-x86_64.zip", "source_type": "zip", "os": "windows", "arch": "x86_64" },
        { "asset_name": "cua-driver-rs-{VERSION}-windows-arm64.zip", "source_type": "zip", "os": "windows", "arch": "aarch64" }
      ]
    },
    {
      "name": "cua-driver-uia",
      "repo": "trycua/cua",
      "binary_name": "cua-driver-uia",
      "release_tag_pattern": "^cua-driver-rs-v",
      "include_prereleases": true,
      "version_probe_regex": "^cua-driver-rs-(?<version>[0-9]+\\.[0-9]+\\.[0-9]+)-.*$",
      "checksum_asset": "checksums.txt",
      "explicit_assets": [
        { "asset_name": "cua-driver-rs-{VERSION}-windows-x86_64.zip", "source_type": "zip", "os": "windows", "arch": "x86_64" },
        { "asset_name": "cua-driver-rs-{VERSION}-windows-arm64.zip", "source_type": "zip", "os": "windows", "arch": "aarch64" }
      ]
    }
  ]
}
